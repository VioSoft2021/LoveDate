# misplaced root-level artifacts
/LoveDate-debug.apk
/page.tsx
/__empty__/
/vite-dev.err.log
/vite-dev.log

# Claude Code local state — ignore everything except the project-shared
# allowlist (settings.json). settings.local.json is per-user and stays
# ignored; conversation transcripts live in ~/.claude/projects/, not here.
.claude/*
!.claude/settings.json

__*.png

# Personal planning docs that happen to live alongside the repo
notes/plans/LoveDate-Plan.*

# Secrets that must NEVER ship to GitHub — domain registrar backup codes,
# 2FA recovery codes, exported API keys, etc. Anything with "BACK-UP",
# "BACKUP CODES", "RECOVERY", "API_KEY" in the filename.
/BACK-UP*.txt
/BACKUP*.txt
/RECOVERY*.txt
/*API_KEY*.txt
/*-credentials.txt
/secrets/

# Ephemeral Supabase CLI local state (writes per-developer machine info)
supabase/.temp/

# Local audit + analysis artifacts that Master keeps in the repo root
# but doesn't want committed (they're scratchpad files)
/AI_COSTS.txt
/AUDIT_*.txt
/AUDIT_RESOLUTION_*.txt

# Large local installers (Android Studio installer is ~1GB)
android-studio*.exe
*-installer.exe

# Android IDE metadata that's per-developer
android/.idea/
